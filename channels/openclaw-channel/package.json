{
  "name": "openclaw-channel-agentclub",
  "version": "0.2.2",
  "description": "OpenClaw channel plugin that connects OpenClaw agents to an Agent Club IM server.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "agentclub",
      "label": "Agent Club",
      "blurb": "Connect OpenClaw to an Agent Club IM server.",
      "markdownCapable": true
    }
  },
  "keywords": [
    "openclaw",
    "agent",
    "chat",
    "channel",
    "agentclub",
    "socketio"
  ],
  "author": "Dante Zhu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantezhu/agentclub.git",
    "directory": "channels/openclaw-channel"
  },
  "bugs": {
    "url": "https://github.com/dantezhu/agentclub/issues"
  },
  "homepage": "https://github.com/dantezhu/agentclub/tree/master/channels/openclaw-channel#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "socket.io-client": "^4.7.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "peerDependenciesMeta": {
    "openclaw": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
